{
  "_comment": "Copy to credentials.json (gitignored) and fill in. See docs/mobile-eas-local-build.md step 3.",
  "ios": {
    "provisioningProfilePath": "credentials/luxuria_appstore.mobileprovision",
    "distributionCertificate": {
      "path": "credentials/dist-cert.p12",
      "password": "REPLACE_WITH_P12_PASSWORD"
    }
  },
  "android": {
    "keystore": {
      "keystorePath": "credentials/luxuria-upload.keystore",
      "keystorePassword": "REPLACE_WITH_KEYSTORE_PASSWORD",
      "keyAlias": "luxuria-upload",
      "keyPassword": "REPLACE_WITH_KEY_PASSWORD"
    }
  }
}
