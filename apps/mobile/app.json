{
  "expo": {
    "name": "Luxuria Homes",
    "slug": "luxuria-homes",
    "version": "1.0.0",
    "scheme": "luxuriahomes",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "au.com.luxuriahomes",
      "buildNumber": "5",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "au.com.luxuriahomes",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EBE0"
      },
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5EBE0",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Luxuria Homes to access your photos to attach images to inclusion notes."
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "051bab2a-c45c-47c7-987e-aea73cceb9c8"
      }
    },
    "owner": "pdomala-kheriox"
  }
}
