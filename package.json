{
  "name": "monorepo-template",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:admin": "turbo -F admin dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "infra:preview:dev": "pnpm --filter @workspace/infra preview:dev",
    "infra:preview:prod": "pnpm --filter @workspace/infra preview:prod",
    "infra:up:dev": "pnpm --filter @workspace/infra up:dev",
    "infra:up:prod": "pnpm --filter @workspace/infra up:prod",
    "infra:destroy:dev": "pnpm --filter @workspace/infra destroy:dev",
    "infra:destroy:prod": "pnpm --filter @workspace/infra destroy:prod"
  },
  "dependencies": {
    "@workspace/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/node": "^20",
    "@workspace/config": "workspace:*",
    "husky": "^9.1.7",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.2.4"
  },
  "packageManager": "pnpm@10.30.3"
}
